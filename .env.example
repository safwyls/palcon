# Copy to .env and fill in. Generate secrets with:
#   openssl rand -hex 32   -> JWT_SECRET (any length works)
#   openssl rand -hex 16   -> ENCRYPTION_KEY (hex-encodes to exactly 32 ASCII chars = 32 bytes)

# Signs session cookies. Changing this invalidates all logged-in sessions.
JWT_SECRET=

# Encrypts stored RCON/REST passwords at rest. Must be EXACTLY 32 bytes/characters.
# Losing this key makes stored server credentials unrecoverable - back it up.
ENCRYPTION_KEY=

# Bootstrap admin account, only used the very first time the app starts
# (when the users table is empty). Change the password after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
