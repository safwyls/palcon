/data/
*.db
*.db-journal
*.db-shm
*.db-wal
.env
app.yaml

# Go
/bin/
*.exe

# Node / frontend
web/node_modules/
web/dist/*
!web/dist/.gitkeep
*.tsbuildinfo

# Palworld world map textures - copyrighted game assets. Supply your own
# copies locally; they're never committed. See web/public/README.md.
web/public/palworld-map.*
web/public/palworld-treemap.*

# Real Palworld saves used for local debugging. These hold player names and
# platform account IDs, and are far too big for the repo — the committed
# fixtures in internal/palsave/testdata/ are synthetic instead.
/localsaves/

# Python bytecode from the save extractor
__pycache__/
*.pyc

# Editor
.vscode/
.idea/
*.swp
